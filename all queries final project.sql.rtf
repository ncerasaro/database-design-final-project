\
-- Business Query 1: AI submissions by department\
SELECT d.department_name, COUNT(a.submission_id) AS total_submissions\
FROM Departments d\
JOIN AI_Use_Submissions a\
ON d.department_id = a.department_id\
GROUP BY d.department_name\
ORDER BY total_submissions DESC;\
\
-- Business Query 2: High priority help desk tickets\
SELECT ticket_id, category, priority_level, status, issue_summary, assigned_team\
FROM Help_Desk_Tickets\
WHERE priority_level = 'High'\
ORDER BY ticket_date DESC;\
\
-- Business Query 3: Most used AI tools\
SELECT t.tool_name, COUNT(*) AS times_used\
FROM AI_Use_Submissions a\
JOIN AI_Tools t\
ON a.tool_id = t.tool_id\
GROUP BY t.tool_name\
ORDER BY times_used DESC;\
\
-- Business Query 4: Forecasts vs actual results\
SELECT s.forecast_id,\
       s.product_category,\
       s.predicted_sales_units,\
       f.actual_sales_units,\
       f.variance_units,\
       s.predicted_revenue,\
       f.actual_revenue,\
       f.variance_revenue\
FROM Sales_Forecasts s\
JOIN Forecast_Results f\
ON s.forecast_id = f.forecast_id\
ORDER BY s.forecast_id\
LIMIT 25;\
\
\
-- New Queries--\
CREATE OR REPLACE VIEW high_priority_ticket_view AS\
SELECT ticket_id, employee_id, priority_level, status, issue_summary\
FROM Help_Desk_Tickets\
WHERE priority_level = 'High';\
SELECT * FROM high_priority_ticket_view LIMIT 20;\
\
CREATE OR REPLACE FUNCTION get_total_high_priority_tickets()\
RETURNS INT\
LANGUAGE plpgsql\
AS $$\
BEGIN\
    RETURN (\
        SELECT COUNT(*)\
        FROM Help_Desk_Tickets\
        WHERE priority_level = 'High'\
    );\
END;\
$$;\
SELECT get_total_high_priority_tickets();\
\
CREATE OR REPLACE PROCEDURE update_ticket_status(p_ticket_id INT, p_new_status VARCHAR)\
LANGUAGE plpgsql\
AS $$\
BEGIN\
    UPDATE Help_Desk_Tickets\
    SET status = p_new_status\
    WHERE ticket_id = p_ticket_id;\
END;\
$$;}