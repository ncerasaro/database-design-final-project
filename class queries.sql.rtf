-- 1. SELECT\
-- =========================================\
SELECT * FROM Employees LIMIT 10;\
\
\
-- =========================================\
-- 2. DELETE\
-- 3. UPDATE\
-- 4. INSERT\
-- using a demo table so the real data is not changed\
-- =========================================\
CREATE TABLE IF NOT EXISTS Demo_Table (\
    id INT PRIMARY KEY,\
    name VARCHAR(50)\
);\
\
INSERT INTO Demo_Table (id, name)\
VALUES (1, 'Test User');\
\
UPDATE Demo_Table\
SET name = 'Updated User'\
WHERE id = 1;\
\
DELETE FROM Demo_Table\
WHERE id = 1;\
\
